@page "/goals/{GoalId:guid}"
@using DailyWork.Web.Models
@using DailyWork.Web.Services
@using MudBlazor
@inject DashboardApiClient Api
@inject NavigationManager Navigation

<PageTitle>Goal Detail - DailyWork</PageTitle>

<MudButton Variant="Variant.Text"
           StartIcon="@Icons.Material.Filled.ArrowBack"
           OnClick="@(() => Navigation.NavigateTo("/goals"))"
           Class="mb-4">
    Back to Goals
</MudButton>

@if (loading)
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="mb-4" />
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px" />
}
else if (error is not null)
{
    <MudAlert Severity="Severity.Error">@error</MudAlert>
}
else if (progress is not null)
{
    <MudPaper Class="pa-6 mb-4" Elevation="2">
        <MudText Typo="Typo.h4" Class="mb-2">@progress.Title</MudText>

        <div class="d-flex align-center gap-4 mb-4">
            <MudText Typo="Typo.h2" Color="Color.Primary">
                @progress.CompletionPercent%
            </MudText>
            <div style="flex: 1;">
                <MudProgressLinear Color="Color.Primary"
                                  Value="@progress.CompletionPercent"
                                  Rounded="true"
                                  Size="Size.Large"
                                  Class="mb-2" />
                <MudText Typo="Typo.body2" Color="Color.Default">
                    @progress.CompletedTodos of @progress.TotalTodos todos completed
                </MudText>
            </div>
        </div>

        <MudGrid>
            <MudItem xs="4">
                <MudPaper Class="pa-3 text-center" Elevation="0" Style="background: rgba(76, 175, 80, 0.1);">
                    <MudText Typo="Typo.h5" Color="Color.Success">@progress.CompletedTodos</MudText>
                    <MudText Typo="Typo.caption">Completed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 text-center" Elevation="0" Style="background: rgba(33, 150, 243, 0.1);">
                    <MudText Typo="Typo.h5" Color="Color.Info">@progress.InProgressTodos</MudText>
                    <MudText Typo="Typo.caption">In Progress</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 text-center" Elevation="0" Style="background: rgba(158, 158, 158, 0.1);">
                    <MudText Typo="Typo.h5" Color="Color.Default">@progress.NotStartedTodos</MudText>
                    <MudText Typo="Typo.caption">Not Started</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (todos.Count > 0)
    {
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Linked Todos</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Due Date</th>
                        <th>Tags</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (TodoSummary todo in todos)
                    {
                        <tr>
                            <td>@todo.Title</td>
                            <td>
                                <MudChip T="string"
                                         Color="@GetStatusColor(todo.Status)"
                                         Size="Size.Small">
                                    @todo.Status
                                </MudChip>
                            </td>
                            <td>
                                <MudChip T="string"
                                         Color="@GetPriorityColor(todo.Priority)"
                                         Size="Size.Small"
                                         Variant="Variant.Outlined">
                                    @todo.Priority
                                </MudChip>
                            </td>
                            <td>@(todo.DueDate ?? "—")</td>
                            <td>
                                @foreach (string tag in todo.Tags)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">#@tag</MudChip>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
}

@code {
    [Parameter] public Guid GoalId { get; set; }

    private GoalProgressSummary? progress;
    private List<TodoSummary> todos = [];
    private bool loading = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Task<GoalProgressSummary?> progressTask = Api.GetGoalProgressAsync(GoalId);
            Task<List<TodoSummary>> todosTask = Api.GetTodosAsync();

            await Task.WhenAll(progressTask, todosTask).ConfigureAwait(false);

            progress = await progressTask.ConfigureAwait(false);
            List<TodoSummary> allTodos = await todosTask.ConfigureAwait(false);

            // Filter to todos linked to this goal
            todos = allTodos.Where(t => t.GoalTitle == progress?.Title).ToList();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private static Color GetStatusColor(string status) =>
        status switch
        {
            "Completed" => Color.Success,
            "InProgress" => Color.Info,
            "NotStarted" => Color.Default,
            _ => Color.Default
        };

    private static Color GetPriorityColor(string priority) =>
        priority switch
        {
            "Critical" => Color.Error,
            "High" => Color.Warning,
            "Medium" => Color.Info,
            "Low" => Color.Default,
            _ => Color.Default
        };
}
