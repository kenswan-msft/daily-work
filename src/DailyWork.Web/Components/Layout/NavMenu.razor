@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>
    <MudNavLink Href="/goals" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.FlagCircle">
        Goals
    </MudNavLink>
    <MudNavLink Href="/todos" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.CheckCircle">
        Todos
    </MudNavLink>
    <MudNavLink Href="/knowledge" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.LibraryBooks">
        Knowledge
    </MudNavLink>
    <MudNavLink Href="/projects" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.AccountTree">
        Projects
    </MudNavLink>
</MudNavMenu>
